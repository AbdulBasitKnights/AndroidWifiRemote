<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:elevation="24dp"
    android:focusable="true"
    android:visibility="gone">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_loader_scrim" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="36dp"
        app:cardBackgroundColor="@color/glass_white_solid"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:strokeColor="@color/primary"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="32dp"
            android:paddingBottom="28dp">

            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/loaderSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:indeterminate="true"
                    app:indicatorColor="@color/primary"
                    app:indicatorSize="96dp"
                    app:trackColor="@color/loader_track"
                    app:trackThickness="3dp" />

                <ImageView
                    android:id="@+id/loaderIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:scaleType="fitCenter"
                    app:tint="@color/primary" />
            </FrameLayout>

            <TextView
                android:id="@+id/loaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/loaderSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/loaderDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:orientation="horizontal">

                <View
                    android:id="@+id/loaderDot1"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_loader_dot" />

                <View
                    android:id="@+id/loaderDot2"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_loader_dot" />

                <View
                    android:id="@+id/loaderDot3"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_loader_dot" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
