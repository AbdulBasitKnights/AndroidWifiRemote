<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/stateOverlayRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="false"
    android:focusable="false"
    android:visibility="gone">

    <LinearLayout
        android:id="@+id/connectingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/tv_off_scrim"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/accent_coral" />

        <TextView
            android:id="@+id/connectingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/inter_medium"
            android:text="@string/connecting_tv"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tvOffOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/tv_off_scrim"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_power"
            app:tint="@color/tv_off_icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:text="@string/tv_off_message"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />
    </LinearLayout>
</FrameLayout>
