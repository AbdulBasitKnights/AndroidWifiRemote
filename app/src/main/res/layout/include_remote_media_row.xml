<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="15dp"
    android:gravity="center"
    android:orientation="horizontal">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:background="@drawable/bg_remote_control_card"
        android:orientation="vertical">

        <ImageButton
            android:id="@+id/rewindButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_remote_btn"
            android:contentDescription="@string/cast_videos_title"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_rewind" />

        <ImageButton
            android:id="@+id/playPauseButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_remote_btn"
            android:contentDescription="@string/cast_videos_title"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_pause" />

        <ImageButton
            android:id="@+id/forwardButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_remote_btn"
            android:contentDescription="@string/cast_videos_title"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_forward" />
    </LinearLayout>

    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:background="@drawable/bg_remote_control_card"
        android:columnCount="3"
        android:gravity="top">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_remote_btn"
            android:contentDescription="@string/back"
            android:padding="12dp"
            android:src="@drawable/ic_back"
            app:tint="@color/text_primary" />
        <ImageView
            android:id="@+id/homeButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:contentDescription="@string/home"
            android:padding="12dp"
            android:background="@drawable/bg_remote_btn"
            android:src="@drawable/ic_home"
            app:tint="@color/text_primary" />
        <ImageButton
            android:id="@+id/muteButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_remote_btn"
            android:contentDescription="@string/cast_audio_title"
            android:padding="12dp"
            android:src="@drawable/ic_mute" />
        <ImageButton
            android:id="@+id/inputButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_remote_btn"
            android:contentDescription="@string/cast_photos_title"
            android:padding="12dp"
            android:visibility="gone"
            android:src="@drawable/ic_photos" />



        <ImageButton
            android:id="@+id/micButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_remote_btn"
            android:contentDescription="@string/cast_audio_title"
            android:padding="12dp"
            android:src="@drawable/ic_mic"
            android:visibility="gone" />


        <ImageButton
            android:id="@+id/appsButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_remote_btn"
            android:contentDescription="@string/nav_settings"
            android:padding="12dp"
            android:src="@drawable/ic_apps"
            android:visibility="gone" />


        <ImageButton
            android:id="@+id/headerSettingsShortcut"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_remote_btn"
            android:contentDescription="@string/ai_feature"
            android:padding="16dp"
            android:src="@drawable/ic_mute"
            android:visibility="gone" />
    </GridLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:background="@drawable/bg_remote_control_card"
        android:orientation="vertical">

        <TextView
            android:id="@+id/volUpButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_remote_btn"
            android:gravity="center"
            android:text="@string/vol_up"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="4dp"
            android:gravity="center"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/volDownButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_remote_btn"
            android:gravity="center"
            android:text="@string/vol_down"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
