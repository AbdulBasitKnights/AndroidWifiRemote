<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:padding="@dimen/screen_padding">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_glass_circle_btn"
                android:contentDescription="@string/back"
                android:padding="8dp"
                android:src="@drawable/ic_back_arrow" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/settings_screen_title"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pro_badge"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="Pro"
                android:textColor="@color/text_on_accent"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/howToConnectRow"
                    style="@style/SettingsRow"
                    android:drawablePadding="12dp"
                    android:text="@string/how_to_connect"
                    app:drawableStartCompat="@drawable/ic_settings_how_to_connect"
                    app:drawableTint="@color/text_primary" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/glass_border" />

                <TextView
                    android:id="@+id/languageButton"
                    style="@style/SettingsRow"
                    android:drawablePadding="12dp"
                    android:text="@string/app_languages"
                    app:drawableStartCompat="@drawable/ic_language"
                    app:drawableTint="@color/text_primary" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/glass_border" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginTop="2dp"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_settings_theme_icon"
                        app:tint="@color/text_primary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/theme_title"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/themeSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/theme_dark"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/themeToggle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/themeLight"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/theme_light"
                            android:textAllCaps="false" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/themeDark"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/theme_dark"
                            android:textAllCaps="false" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/themeSystem"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/theme_system"
                            android:textAllCaps="false" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/others_section"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/cantFindRow"
                    style="@style/SettingsRow"
                    android:drawablePadding="12dp"
                    android:text="@string/cant_find_remote"
                    app:drawableStartCompat="@drawable/ic_settings_not_found_icon"
                    app:drawableTint="@color/text_primary" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/glass_border" />

                <TextView
                    android:id="@+id/feedbackRow"
                    style="@style/SettingsRow"
                    android:drawablePadding="12dp"
                    android:text="@string/feedback"
                    app:drawableStartCompat="@drawable/ic_settings_feedback_icon"
                    app:drawableTint="@color/text_primary" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/glass_border" />

                <TextView
                    android:id="@+id/rateRow"
                    style="@style/SettingsRow"
                    android:drawablePadding="12dp"
                    android:text="@string/rate_us"
                    app:drawableStartCompat="@drawable/ic_settings_rate_icon"
                    app:drawableTint="@color/text_primary" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/glass_border" />

                <TextView
                    android:id="@+id/shareRow"
                    style="@style/SettingsRow"
                    android:drawablePadding="12dp"
                    android:text="@string/share_app"
                    app:drawableStartCompat="@drawable/ic_settings_share_icon"
                    app:drawableTint="@color/text_primary" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/glass_border" />

                <TextView
                    android:id="@+id/privacyRow"
                    style="@style/SettingsRow"
                    android:drawablePadding="12dp"
                    android:text="@string/privacy_policy"
                    app:drawableStartCompat="@drawable/ic_settings_privacy_icon"
                    app:drawableTint="@color/text_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/versionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
