<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="5dp"
    android:background="@color/splash_background"
    android:orientation="vertical">

    <include
        android:id="@+id/remoteTopBar"
        layout="@layout/include_remote_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/screen_padding"
        android:paddingTop="@dimen/screen_padding" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- REMOTE CONTROLS PANEL (always visible, bottom layer) -->
        <ScrollView
            android:id="@+id/remotePanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:padding="@dimen/screen_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/modeToggle"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_mode_toggle_track"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/modeDpad"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:fontFamily="@font/inter_medium"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:padding="0dp"
                        android:text="@string/mode_remote"
                        android:textAllCaps="false"
                        android:textColor="@color/mode_toggle_tint"
                        android:textSize="13sp"
                        app:backgroundTint="@color/mode_toggle_bg"
                        app:cornerRadius="26dp"
                        app:strokeWidth="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/modeTouchpad"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:fontFamily="@font/inter_medium"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:padding="0dp"
                        android:text="@string/mode_touchpad"
                        android:textAllCaps="false"
                        android:textColor="@color/mode_toggle_tint"
                        android:textSize="13sp"
                        app:backgroundTint="@color/mode_toggle_bg"
                        app:cornerRadius="26dp"
                        app:strokeWidth="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/modeNumpad"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:padding="0dp"
                        android:text="@string/mode_number"
                        android:textAllCaps="false"
                        android:textColor="@color/mode_toggle_tint"
                        android:textSize="13sp"
                        android:visibility="gone"
                        app:backgroundTint="@color/mode_toggle_bg"
                        app:cornerRadius="20dp"
                        app:strokeWidth="0dp" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <LinearLayout
                    android:id="@+id/lowBatteryBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_low_battery_banner"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/inter_medium"
                        android:text="@string/low_battery_remote"
                        android:textColor="@color/low_battery_text"
                        android:textSize="13sp" />

                    <ImageButton
                        android:id="@+id/lowBatteryDismiss"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/back"
                        android:padding="6dp"
                        android:src="@drawable/ic_cross"
                        app:tint="@color/low_battery_text" />
                </LinearLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:minHeight="300dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:elevation="1dp"
                        android:minHeight="280dp"
                        android:padding="12dp">

                        <include
                            android:id="@+id/dpadPanel"
                            layout="@layout/layout_remote_dpad" />

                        <FrameLayout
                            android:id="@+id/touchpadPanel"
                            android:layout_width="match_parent"
                            android:layout_height="260dp"
                            android:background="@drawable/bg_touchpad_surface"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:fontFamily="@font/inter_medium"
                                android:text="@string/swipe_to_navigate"
                                android:textColor="@color/touchpad_hint"
                                android:textSize="14sp" />
                        </FrameLayout>

                        <com.tvremote.app.ui.remote.RemoteKeyboardView
                            android:id="@+id/numpadPanel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:visibility="gone" />
                    </FrameLayout>

                    <include
                        android:id="@+id/stateOverlay"
                        layout="@layout/include_remote_state_overlay" />
                </FrameLayout>

                <include
                    android:id="@+id/mediaRow"
                    layout="@layout/include_remote_media_row" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <ImageButton
                        android:id="@+id/backNavButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_remote_btn"
                        android:contentDescription="@string/back"
                        android:padding="12dp"
                        android:src="@drawable/ic_back"
                        app:tint="@color/text_primary" />

                    <ImageView
                        android:id="@+id/homeButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_remote_btn"
                        android:contentDescription="@string/home"
                        android:padding="12dp"
                        android:src="@drawable/ic_home"
                        app:tint="@color/text_primary" />

                    <ImageButton
                        android:id="@+id/appsNavButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_remote_btn"
                        android:contentDescription="@string/nav_settings"
                        android:padding="12dp"
                        android:src="@drawable/ic_apps"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- CONNECT / PAIR PANEL (overlay on top of remote) -->
        <ScrollView
            android:id="@+id/connectPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/splash_background"
            android:clickable="true"
            android:clipToPadding="false"
            android:elevation="16dp"
            android:fillViewport="true"
            android:focusable="true"
            android:overScrollMode="never"
            android:padding="@dimen/screen_padding"
            android:visibility="gone"
            tools:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/remote_tab_title"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/connectPanelClose"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/img_btn_circle_dark"
                        android:contentDescription="@string/back"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_back"
                        app:tint="@color/text_primary" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineSpacingExtra="4dp"
                    android:text="@string/connect_wifi_hint"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/rescanButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/scan_tvs"
                    android:textAllCaps="false" />

                <TextView
                    android:id="@+id/scanStatusLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="@string/scanning_tvs"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/discoveredTvsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="2"
                    tools:listitem="@layout/item_discovered_tv" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/pairingCodeCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/accent_purple"
                    app:strokeWidth="2dp"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pairing_code_step_title"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="@string/pairing_code_hint">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/codeInput"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:imeOptions="actionDone"
                                android:inputType="textCapCharacters"
                                android:maxLength="6"
                                android:textSize="20sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/completePairingButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:backgroundTint="@color/accent_purple"
                            android:text="@string/complete_pairing"
                            android:textAllCaps="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/reconnectButton"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:text="@string/reconnect_remote"
                        android:textAllCaps="false"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/disconnectButton"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:text="@string/disconnect_remote"
                        android:textAllCaps="false"
                        android:textColor="@color/accent_red"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </LinearLayout>

                <TextView
                    android:id="@+id/manualIpToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:padding="8dp"
                    android:text="@string/enter_ip_manually"
                    android:textColor="@color/accent_purple" />

                <LinearLayout
                    android:id="@+id/manualIpSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/tv_ip_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/hostInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/pairManualButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="@color/accent_purple"
                        android:text="@string/pair_now"
                        android:textAllCaps="false" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <include
            android:id="@+id/connectionLoader"
            layout="@layout/include_connection_loader"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>
</LinearLayout>
