<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_title"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/powerButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_glass_circle_btn"
                android:contentDescription="@string/mirror_title"
                android:padding="8dp"
                android:src="@drawable/ic_power" />

            <ImageButton
                android:id="@+id/headerCastButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_glass_circle_btn"
                android:contentDescription="@string/nav_cast"
                android:padding="8dp"
                android:src="@drawable/ic_cast" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/appShortcutsRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/netflixChip"
                    style="@style/GlassChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="@string/shortcut_netflix" />

                <TextView
                    android:id="@+id/youtubeChip"
                    style="@style/GlassChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="@string/shortcut_youtube" />

                <TextView
                    android:id="@+id/primeChip"
                    style="@style/GlassChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="@string/shortcut_prime" />

                <TextView
                    android:id="@+id/hotstarChip"
                    style="@style/GlassChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/shortcut_hotstar" />
            </LinearLayout>
        </HorizontalScrollView>

        <FrameLayout
            android:layout_width="@dimen/remote_dpad_size"
            android:layout_height="@dimen/remote_dpad_size"
            android:layout_marginTop="20dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_dpad_ring"
            android:gravity="center">
            <ImageButton
                android:id="@+id/upButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="top|center_horizontal"
                android:background="@android:color/transparent"
                android:contentDescription="@string/up"
                android:src="@drawable/ic_arrow_up" />

            <ImageButton
                android:id="@+id/downButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="bottom|center_horizontal"
                android:background="@android:color/transparent"
                android:contentDescription="@string/down"
                android:src="@drawable/ic_arrow_down" />

            <ImageButton
                android:id="@+id/leftButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center_vertical|start"
                android:background="@android:color/transparent"
                android:contentDescription="@string/left"
                android:src="@drawable/ic_arrow_left" />

            <ImageButton
                android:id="@+id/rightButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center_vertical|end"
                android:background="@android:color/transparent"
                android:contentDescription="@string/right"
                android:src="@drawable/ic_arrow_right" />

            <TextView
                android:id="@+id/okButton"
                android:layout_width="@dimen/remote_ok_size"
                android:layout_height="@dimen/remote_ok_size"
                android:layout_gravity="center"
                android:background="@drawable/bg_dpad_ok"
                android:gravity="center"
                android:text="@string/ok"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="@dimen/volume_slider_width"
                android:layout_height="@dimen/volume_slider_height"
                android:background="@drawable/bg_volume_slider">

                <View
                    android:id="@+id/volumeFill"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bg_volume_fill" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/volUpButton"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/vol_up"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:visibility="gone"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/volDownButton"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/vol_down"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/inputButton"
                        style="@style/GlassCircleButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_margin="4dp"
                        android:contentDescription="@string/cast_photos_title"
                        android:src="@drawable/ic_photos" />

                    <ImageButton
                        android:id="@+id/homeButton"
                        style="@style/GlassCircleButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_margin="4dp"
                        android:contentDescription="@string/home"
                        android:src="@drawable/ic_home" />

                    <ImageButton
                        android:id="@+id/appsButton"
                        style="@style/GlassCircleButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_margin="4dp"
                        android:contentDescription="@string/nav_settings"
                        android:src="@drawable/ic_apps" />
                </LinearLayout>

                <FrameLayout
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_marginVertical="8dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_mic_glow" />

                    <ImageButton
                        android:id="@+id/micButton"
                        style="@style/GlassCircleButton"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/cast_audio_title"
                        android:src="@drawable/ic_mic" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/muteButton"
                        style="@style/GlassCircleButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_margin="4dp"
                        android:contentDescription="@string/cast_audio_title"
                        android:src="@drawable/ic_mute" />

                    <ImageButton
                        android:id="@+id/backButton"
                        style="@style/GlassCircleButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_margin="4dp"
                        android:contentDescription="@string/back"
                        android:src="@drawable/ic_back" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/rewindButton"
                        style="@style/GlassCircleButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_margin="4dp"
                        android:contentDescription="@string/cast_videos_title"
                        android:src="@drawable/ic_rewind" />

                    <ImageButton
                        android:id="@+id/playPauseButton"
                        style="@style/GlassCircleButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_margin="4dp"
                        android:contentDescription="@string/cast_videos_title"
                        android:src="@drawable/ic_pause" />

                    <ImageButton
                        android:id="@+id/forwardButton"
                        style="@style/GlassCircleButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_margin="4dp"
                        android:contentDescription="@string/cast_videos_title"
                        android:src="@drawable/ic_forward" />
                </LinearLayout>
            </LinearLayout>

            <FrameLayout
                android:layout_width="@dimen/volume_slider_width"
                android:layout_height="@dimen/volume_slider_height"
                android:background="@drawable/bg_volume_slider">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/channelUpButton"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/channel_up"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ch"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/channelDownButton"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/channel_down"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/connectionStatusLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_glass_panel"
            android:gravity="center"
            android:padding="10dp"
            android:text="@string/not_connected"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
