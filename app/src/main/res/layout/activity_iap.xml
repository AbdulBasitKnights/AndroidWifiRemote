<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgColor">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/iapScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingHorizontal="@dimen/_12sdp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/btnContinue"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="@dimen/_62sdp"
            android:paddingBottom="@dimen/_4sdp">

            <FrameLayout
                android:layout_width="@dimen/_75sdp"
                android:layout_height="@dimen/_75sdp"
                android:padding="@dimen/_3sdp">

                <ImageView
                    android:id="@+id/ivAppIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:padding="@dimen/_1sdp"
                    android:src="@drawable/bg_remote_btn"
                    android:scaleType="centerCrop" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_16sdp"
                android:fontFamily="@font/inter_bold"
                android:gravity="center"
                android:text="@string/iap_unlock_title"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/_18ssp" />

            <TextView
                android:id="@+id/tvPriceInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:textSize="@dimen/_10ssp"
                android:textColor="#575757"
                android:gravity="center"
                android:visibility="visible"/>

            <TextView
                android:id="@+id/textFetchingPrices"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_8sdp"
                android:fontFamily="@font/inter_medium"
                android:text="@string/iap_fetching_prices"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/_10ssp"
                android:visibility="invisible" />

            <TextView
                android:id="@+id/tvWhatsIncluded"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:gravity="center"
                android:layout_marginTop="@dimen/_10sdp"
                android:text="@string/iap_whats_included"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/_14ssp" />

            <LinearLayout
                android:id="@+id/cardFeatures"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_marginBottom="@dimen/_3sdp"
                android:background="@drawable/bg_iap_card"
                android:elevation="@dimen/_1sdp"
                android:layout_marginHorizontal="@dimen/_3sdp"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/_12sdp"
                android:paddingTop="@dimen/_14sdp"
                android:paddingBottom="@dimen/_10sdp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingBottom="@dimen/_12sdp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/textView2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:fontFamily="@font/inter_medium"
                        android:text="@string/iap_basic"
                        android:textAllCaps="true"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/_9ssp" />

                    <TextView
                        android:id="@+id/textView3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_medium"
                        android:text="@string/iap_premium"
                        android:textAllCaps="true"
                        android:textColor="@color/colorIAPHighlight"
                        android:textSize="@dimen/_9ssp" />
                </LinearLayout>

                <include layout="@layout/item_iap_feature_row_hd_camera" />
                <include layout="@layout/item_iap_feature_row_body_editor" />
                <include layout="@layout/item_iap_feature_row_collage" />
                <include layout="@layout/item_iap_feature_row_nanobanana" />
                <include layout="@layout/item_iap_feature_row_enhancer" />
                <include layout="@layout/item_iap_feature_row_remove_ads" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardFreeTrial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_iap_card"
                android:elevation="@dimen/_1sdp"
                android:layout_marginTop="@dimen/_12sdp"
                android:layout_marginBottom="@dimen/_7sdp"
                android:layout_marginHorizontal="@dimen/_3sdp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/_16sdp"
                android:paddingVertical="@dimen/_13sdp">

                <TextView
                    android:id="@+id/tvEnableFreeTrial"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter_semibold"
                    android:text="@string/iap_enable_free_trial"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/_13ssp" />

                <com.tvremote.app.util.IosToggleView
                    android:id="@+id/switchFreeTrial"
                    android:layout_width="48dp"
                    android:layout_height="26dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardPurchase"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_3sdp"
                android:layout_marginTop="@dimen/_12sdp"
                android:layout_marginBottom="@dimen/_7sdp"
                android:background="@drawable/bg_iap_card"
                android:elevation="@dimen/_1sdp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/_16sdp"
                android:paddingVertical="@dimen/_13sdp">

                <TextView
                    android:id="@+id/tvEnablePurchase"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:lineSpacingExtra="2dp"
                    tools:text="Weekly\n$ / Weekly" />

                <TextView
                    android:id="@+id/tvPurchaseBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end|center_vertical"
                    android:lineSpacingExtra="2dp"
                    tools:text="Trial Disabled\nCancel Anytime" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvDisclaimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_6sdp"
                android:layout_marginTop="@dimen/_4sdp"
                android:layout_marginBottom="@dimen/_8sdp"
                android:fontFamily="@font/inter_regular"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/_10ssp"
                tools:text="Payment will be charged to your Google Play account upon purchase confirmation." />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <ImageView
        android:id="@+id/closeButton"
        android:layout_width="@dimen/_36sdp"
        android:layout_height="@dimen/_36sdp"
        android:layout_marginStart="@dimen/_12sdp"
        android:layout_marginTop="@dimen/_20sdp"
        android:contentDescription="@string/close"
        android:padding="@dimen/_8sdp"
        android:src="@drawable/ic_cross"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text_primary"
        tools:visibility="visible" />
    <TextView
        android:id="@+id/btnContinue"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_20sdp"
        android:layout_marginBottom="@dimen/_8sdp"
        android:background="@drawable/bg_iap_cta_orange"
        android:fontFamily="@font/inter_bold"
        android:gravity="center"
        android:paddingVertical="@dimen/_12sdp"
        android:paddingHorizontal="@dimen/_20sdp"
        android:drawablePadding="@dimen/_8sdp"
        android:text="@string/iap_continue"
        android:textColor="@color/white"
        android:textSize="@dimen/_15ssp"
        app:drawableEndCompat="@drawable/ic_iap_arrow_right"
        app:drawableTint="@color/white"
        app:layout_constraintBottom_toTopOf="@id/tvNoPaymentNow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvNoPaymentNow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/_8sdp"
        android:fontFamily="@font/inter_medium"
        android:gravity="center"
        android:text="@string/iap_cancel_anytime"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/_11ssp"
        app:layout_constraintBottom_toTopOf="@id/tvContinueAds"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvContinueAds"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/_8sdp"
        android:fontFamily="@font/inter_regular"
        android:gravity="center"
        android:text="@string/iap_continue_with_ads"
        android:paddingVertical="@dimen/_5sdp"
        android:textColor="@color/primaryColor"
        android:textSize="@dimen/_10ssp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/llFooterLinks"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:visibility="visible" />

    <LinearLayout
        android:id="@+id/llFooterLinks"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/_16sdp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tv_terms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_regular"
            android:text="@string/terms_of_use"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/_10ssp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_10sdp"
            android:text="|"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/_10ssp" />

        <TextView
            android:id="@+id/tv_privacy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_regular"
            android:text="@string/privacy_policy"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/_10ssp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSubInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/progressbar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvPlzWait"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter_medium"
        android:text="@string/please_wait"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/_11ssp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/progressbar" />

    <!-- Legacy ids kept for binding compatibility -->
    <ImageView
        android:id="@+id/imgBanner"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/shade"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/llFeatures"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
