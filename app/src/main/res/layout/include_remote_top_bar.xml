<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageButton
        android:id="@+id/powerButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_power_orange"
        android:contentDescription="@string/nav_remote"
        android:padding="10dp"
        android:src="@drawable/ic_power"
        app:tint="@color/text_on_accent" />

    <LinearLayout
        android:id="@+id/devicePill"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginHorizontal="10dp"
        android:layout_weight="1"
        android:background="@drawable/bg_device_pill"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp">

        <View
            android:id="@+id/deviceStatusDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_status_dot" />

        <TextView
            android:id="@+id/deviceNameLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/not_connected"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/settingsButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/img_btn_circle_dark"
        android:contentDescription="@string/nav_settings"
        android:padding="10dp"
        android:src="@drawable/ic_settings"
        app:tint="@color/text_primary" />
</LinearLayout>
